# Copy this file to .env and fill in your key, or export these directly in your shell.

# "mock" runs entirely offline with a free rule-based stand-in agent (no key needed).
# "openrouter" calls the real Claude model through your OpenRouter key.
LLM_BACKEND=mock

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug on OpenRouter. Sonnet is the safest default for reliable tool
# calling; swap to anthropic/claude-haiku-4.5 for cheaper eval runs, or
# anthropic/claude-sonnet-4.6 / anthropic/claude-sonnet-5 for the newest.
# Check https://openrouter.ai/models?q=claude for current slugs + pricing.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
